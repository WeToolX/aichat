# =========================
# 应用基础配置
# =========================

# 项目名称
APP_NAME=aichat-api

# 运行环境，可选：production / local
APP_ENV=local

# 当前网站访问地址，用于安装页自请求检测
APP_URL=http://127.0.0.1

# 时区
APP_TIMEZONE=Asia/Shanghai

# 是否开启调试
APP_DEBUG=true

# Token 有效期，单位秒
APP_TOKEN_TTL=604800

# Token 前缀
APP_TOKEN_PREFIX=aichat:token:

# =========================
# MySQL 数据库配置
# =========================

# 数据库主机
DB_HOST=host.docker.internal

# 数据库端口
DB_PORT=3306

# 数据库名称
DB_DATABASE=shujuguanli

# 数据库账号
DB_USERNAME=root

# 数据库密码
DB_PASSWORD=123456

# 数据库字符集
DB_CHARSET=utf8mb4

# =========================
# Redis 配置
# =========================

# Redis 主机
REDIS_HOST=host.docker.internal

# Redis 端口
REDIS_PORT=6379

# Redis 密码，没有则留空
REDIS_PASSWORD=

# Redis 库编号
REDIS_DB=0

# Redis 超时时间
REDIS_TIMEOUT=2.5

# =========================
# DeepSeek 配置
# =========================

# DeepSeek API Key
DEEPSEEK_API_KEY=

# DeepSeek 接口地址
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# DeepSeek 模型
DEEPSEEK_MODEL=deepseek-chat

# 最大 token 数
DEEPSEEK_MAX_TOKENS=1024

# 温度参数
DEEPSEEK_TEMPERATURE=0.7
