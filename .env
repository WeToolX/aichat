# =========================
# 应用基础配置
# =========================

# 项目名称
APP_NAME=aichat-api

# 运行环境，可选：production / local
APP_ENV=local

# 当前网站访问地址，用于安装页自请求检测
APP_URL=http://122.51.187.121:7788

# 时区
APP_TIMEZONE=Asia/Shanghai

# 是否开启调试
APP_DEBUG=true

# Token 有效期，单位秒
APP_TOKEN_TTL=604800

# Token 前缀
APP_TOKEN_PREFIX=aichat:token:

# =========================
# MySQL 数据库配置
# =========================

# 数据库主机
DB_HOST=127.0.0.1

# 数据库端口
DB_PORT=3306

# 数据库名称
DB_DATABASE=aichat

# 数据库账号
DB_USERNAME=aichat

# 数据库密码
DB_PASSWORD=0dda2c641d3e98

# 数据库字符集
DB_CHARSET=utf8mb4

# =========================
# Redis 配置
# =========================

# Redis 主机
REDIS_HOST=127.0.0.1

# Redis 端口
REDIS_PORT=6379

# Redis 密码，没有则留空
REDIS_PASSWORD=

# Redis 库编号
REDIS_DB=

# Redis 超时时间
REDIS_TIMEOUT=2.5

# =========================
# DeepSeek 配置
# =========================

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-ac3c531041dd432a9b4118d2dc2d06cd

# DeepSeek 接口地址
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# DeepSeek 模型
DEEPSEEK_MODEL=deepseek-chat

# 最大 token 数
DEEPSEEK_MAX_TOKENS=1024

# 温度参数
DEEPSEEK_TEMPERATURE=0.7
SYSTEM_NAME=后台管理系统
SYSTEM_VERSION=1.0.0
SYSTEM_UPLOAD_PATH=uploads/
SYSTEM_MAX_UPLOAD_SIZE=20971520
SYSTEM_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,txt,wb,wb2,wbk,iec


# =========================
# 调试部署接口
# =========================

# 仅在 APP_DEBUG=true 时生效，是否开放拉码接口
DEPLOY_DEBUG_ALLOW_PULL=true

# 调试部署接口密钥，调用时通过 X-Deploy-Token / token 传递
DEPLOY_WEBHOOK_TOKEN=21c82c800cfdc7ab0f139127127847bb858fe15f97ffcb88f481d23b246ac73d

# 服务器固定执行的拉码命令，只建议使用 git pull --ff-only
DEPLOY_PULL_COMMAND=git pull --ff-only

# 拉码执行目录，默认当前项目根目录
DEPLOY_WORKDIR=

# 允许调用的来源 IP，多个用逗号分隔，留空表示不限制
DEPLOY_ALLOWED_IPS=